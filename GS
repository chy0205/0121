function getUserHomeworkHistory(group, name) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const history = [];
  ss.getSheets().forEach(s => {
    if (s.getName().indexOf('作業_') === 0) {
      const topic = s.getName().replace('作業_', '');
      const data = s.getDataRange().getValues();
      data.slice(1).forEach(row => {
        if (row[1] == group && row[2] == name) {
          history.push({ topic: topic, time: row[0] instanceof Date ? Utilities.formatDate(row[0], "GMT+8", "yyyy/MM/dd HH:mm") : row[0].toString(), reflection: row[4] ? row[4].toString() : "", url: row[5] ? row[5].toString() : "" });
        }
      });
    }
  });
  return { success: true, data: history.sort((a,b) => new Date(b.time) - new Date(a.time)) };
}

function getQuizQuestions(type, includeAnswer = false) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const gids = { '隨堂': '0', '論語': '1250135497', '性理': '1342680959', '道德經': '1246480043', '六祖': '1302889740' };
    const fetchSheetData = (gid) => {
      const sheet = ss.getSheets().find(s => s.getSheetId().toString() === gid);
      if (!sheet) return [];
      const rows = sheet.getDataRange().getValues();
      return rows.slice(1).map(cells => {
        const cell0 = (cells[0] || "").toString().trim(), cell1 = (cells[1] || "").toString().trim();
        const isId = cell0.length > 0 && cell0.length <= 5 && /^[Qq\d\.\s]+$/.test(cell0);
        const offset = (isId && cell1.length > cell0.length) ? 1 : 0;
        const qText = (cells[offset + 0] || "").toString().trim();
        if (!qText || qText === "題目") return null;
        const result = {
          question: qText,
          type: (cells[offset + 1] || 'single').toString().toLowerCase().trim(),
          options: (cells[offset + 2] || "").toString().split(/[,，\n;]+/).map(s => s.trim()).filter(s => s),
          score: parseFloat(cells[offset + 4] || 0),
          photo: (cells[offset + 5] || "").toString().trim(),
          isBonus: ['是', 'yes', 'true', 'y', '1'].includes((cells[offset + 6] || '').toString().toLowerCase().trim())
        };
        if (includeAnswer) result.answer = (cells[offset + 3] || "").toString().split(/[,，\n;]+/).map(s => s.trim()).filter(s => s);
        return result;
      }).filter(q => q !== null && q.question);
    };
    if (type === "ALL_FOR_SUBMIT") { // 特殊模式用於評分
       // 這裡需要邏輯來抓取所有可能的題目或者根據傳入的科目抓取
       return { success: true }; 
    }
    const q1 = fetchSheetData(gids['隨堂']);
    const q2 = type ? fetchSheetData(gids[type]) : [];
    return { success: true, data: [...q1, ...q2] };
  } catch (e) { return { success: false, error: e.toString() }; }
}

function handleSubmitQuiz(p) {
  const monthStr = Utilities.formatDate(new Date(), "GMT+8", "yyyy/MM");
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheetName = '結果' + monthStr;
  let sheet = ss.getSheetByName(sheetName) || ss.insertSheet(sheetName);
  let headers = ['時間戳記', '組別', '姓名', '科目', '分數', '詳情'];
  const ua = JSON.parse(p.userAnswersJson);
  const qd = getQuizQuestions(p.quizType, true).data; 
  let score = 0;
  const details = ua.map((u, i) => {
    const q = qd[i];
    if (!q) return { question: "未知題目", userAnswer: u.userAnswer, correctAnswer: "無", isCorrect: false };
    const isCorrect = u.isBonus ? (u.userAnswer !== '未作答') : [].concat(q.answer).some(a => a.toString().trim().toLowerCase() === u.userAnswer.toString().trim().toLowerCase());
    if (isCorrect) score += (parseFloat(q.score) || 0);
    return { question: q.question, userAnswer: u.userAnswer, correctAnswer: [].concat(q.answer).join(','), isCorrect };
  });
  details.forEach((d, index) => {
    const qPrefix = `[Q${index + 1}]`;
    const h1 = `${qPrefix} 正確答案`, h2 = `${qPrefix} 學員作答`, h3 = `${qPrefix} 是否答對`;
    if (headers.indexOf(h1) === -1) headers.push(h1);
    if (headers.indexOf(h2) === -1) headers.push(h2);
    if (headers.indexOf(h3) === -1) headers.push(h3);
  });
  if (sheet.getLastRow() === 0) { sheet.appendRow(headers); sheet.getRange(1, 1, 1, headers.length).setBackground('#e0e7ff').setFontWeight('bold'); }
  else {
    let existingHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0], headerUpdated = false;
    headers.forEach(h => { if (existingHeaders.indexOf(h) === -1) { existingHeaders.push(h); headerUpdated = true; } });
    if (headerUpdated) { sheet.getRange(1, 1, 1, existingHeaders.length).setValues([existingHeaders]); sheet.getRange(1, 1, 1, existingHeaders.length).setBackground('#e0e7ff').setFontWeight('bold'); }
  }
  const finalHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const rowData = new Array(finalHeaders.length).fill('');
  rowData[0] = new Date(); rowData[1] = p.group; rowData[2] = p.name; rowData[3] = p.quizType; rowData[4] = score; rowData[5] = JSON.stringify(details);
  details.forEach((d, index) => {
     const qPrefix = `[Q${index + 1}]`;
     const idx1 = finalHeaders.indexOf(`${qPrefix} 正確答案`), idx2 = finalHeaders.indexOf(`${qPrefix} 學員作答`), idx3 = finalHeaders.indexOf(`${qPrefix} 是否答對`);
     if (idx1 !== -1) rowData[idx1] = d.correctAnswer; if (idx2 !== -1) rowData[idx2] = d.userAnswer; if (idx3 !== -1) rowData[idx3] = d.isCorrect ? '⭕ 是' : '❌ 否';
  });
  sheet.appendRow(rowData);
  logAction(p.name, p.group, "提交測驗", `科目: ${p.quizType}, 分數: ${score}`, p.name);
  return { status: 'success', score };
}

function handleGetConfig() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('Config') || ss.insertSheet('Config');
  const data = sheet.getDataRange().getValues();
  const config = {};
  data.slice(1).forEach(r => { if(r[0]) config[r[0].toString().trim()] = { start: r[1] instanceof Date ? Utilities.formatDate(r[1], "GMT+8", "yyyy-MM-dd HH:mm") : r[1].toString(), end: r[2] ? (r[2] instanceof Date ? Utilities.formatDate(r[2], "GMT+8", "yyyy-MM-dd HH:mm") : r[2].toString()) : "" }; });
  return config;
}

function handleUpdateConfig(configStr) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('Config') || ss.insertSheet('Config');
  const updates = JSON.parse(configStr), data = sheet.getDataRange().getValues();
  for (let key in updates) {
    let found = false;
    for(let i=1; i<data.length; i++) { if(data[i][0] == key) { sheet.getRange(i+1, 2, 1, 2).setValues([[updates[key].start, updates[key].end || ""]]); found = true; break; } }
    if(!found) sheet.appendRow([key, updates[key].start, updates[key].end || ""]);
  }
  return { success: true };
}

function getAnnouncements() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('Bulletin') || ss.insertSheet('Bulletin');
  const data = sheet.getDataRange().getValues();
  return { success: true, data: data.slice(1).map((r, i) => ({ id: i+2, time: r[0] instanceof Date ? Utilities.formatDate(r[0], "GMT+8", "yyyy/MM/dd HH:mm") : r[0].toString(), title: r[1], content: r[2], link: r[3], visible: r[4] || 'Y' })).reverse() };
}

function updateAnnouncement(p) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('Bulletin');
  const vals = [[new Date(), p.title, p.content, p.link, p.visible]];
  if (p.id) sheet.getRange(parseInt(p.id), 1, 1, 5).setValues(vals); else sheet.appendRow(vals[0]);
  return { success: true };
}

function getLocationsData() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName('Locations') || ss.insertSheet('Locations');
  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return { success: true, data: [{ name: "中心地點", lat: 24.13388, lng: 120.71792, radius: 500 }] };
  return { success: true, data: data.slice(1).map(row => ({ name: row[0].toString(), lat: parseFloat(row[1]), lng: parseFloat(row[2]), radius: parseFloat(row[3]) || 500 })).filter(loc => !isNaN(loc.lat)) };
}
