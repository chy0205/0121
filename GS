function getBonusStats(targetSheetName) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheets = ss.getSheets();
  const bonusSheets = sheets.filter(s => s.getName().indexOf('加分_') === 0).sort((a, b) => b.getName().localeCompare(a.getName()));
  const groups = ["第一組", "第二組", "第三組", "第四組", "第五組", "第六組", "第七組", "孟加拉", "德國", "印尼", "馬來", "馬來西亞", "神州", "主領班", "特助"];
  const sheetStats = {}, totalStats = {};
  groups.forEach(g => { sheetStats[g] = 0; totalStats[g] = 0; });
  const availableSheets = bonusSheets.map(s => s.getName());
  if (bonusSheets.length === 0) return { success: true, latest: sheetStats, total: totalStats, sheetName: "", availableSheets: [] };
  let targetSheet = bonusSheets[0];
  if (targetSheetName) { const found = bonusSheets.find(s => s.getName() === targetSheetName); if (found) targetSheet = found; }
  const sheetData = targetSheet.getDataRange().getValues();
  if (sheetData.length > 1) {
    sheetData.slice(1).forEach(row => {
      const group = row[1] ? row[1].toString().trim() : "";
      const pts = parseFloat(row[3]) || 0;
      if (groups.indexOf(group) !== -1) sheetStats[group] += pts;
    });
  }
  bonusSheets.forEach(s => {
    const d = s.getDataRange().getValues();
    if (d.length > 1) {
      d.slice(1).forEach(row => {
        const group = row[1] ? row[1].toString().trim() : "";
        const pts = parseFloat(row[3]) || 0;
        if (groups.indexOf(group) !== -1) totalStats[group] += pts;
      });
    }
  });
  return { success: true, latest: sheetStats, total: totalStats, sheetName: targetSheet.getName(), availableSheets: availableSheets, labels: groups };
}

